{:paths ["src" "test" "resources"]
 :tasks
 {build {:doc "Write the static CLJC/render-IR authority surface."
         :task (clojure.java.shell/sh "bash" "scripts/build.sh")}
  serve {:doc "Serve the built app at http://localhost:8200."
         :task (babashka.process/shell {:dir "public"} "python3 -m http.server 8200")}
  test
  {:doc "Run the pure-cljc board core tests (no external deps)."
   :requires ([clojure.test :as t] [freeboard.board-test] [freeboard.ops-test]
              [freeboard.scene-test] [freeboard.collab-test] [freeboard.interop-test])
   :task (let [{:keys [fail error]} (t/run-tests 'freeboard.board-test 'freeboard.ops-test
                                                 'freeboard.scene-test 'freeboard.collab-test
                                                 'freeboard.interop-test)]
           (System/exit (if (pos? (+ fail error)) 1 0)))}}}
